# Neon Postgres (DucLake catalog + SQLMesh state)
POSTGRES_HOST=your-neon-host.neon.tech
POSTGRES_PORT=5432
POSTGRES_DB=neondb
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_CONNECTION_STRING=postgresql://your_user:your_password@your-neon-host.neon.tech:5432/neondb?sslmode=require

# Cloudflare R2 (S3-compatible object storage)
AWS_ACCESS_KEY_ID=your_r2_access_key
AWS_SECRET_ACCESS_KEY=your_r2_secret_key
AWS_REGION=auto
R2_S3_ENDPOINT=your_account_id.r2.cloudflarestorage.com

# DucLake
DUCKLAKE_DATA_PATH=s3://your-bucket-name/epl_mastermind
DUCKLAKE_NAME=epl_mastermind

# dlt destination config (derived from above)
DESTINATION__DUCKLAKE__CREDENTIALS__CATALOG=${POSTGRES_CONNECTION_STRING}
DESTINATION__DUCKLAKE__CREDENTIALS__STORAGE__BUCKET_URL=${DUCKLAKE_DATA_PATH}
DESTINATION__DUCKLAKE__CREDENTIALS__ENDPOINT_URL=https://${R2_S3_ENDPOINT}
DESTINATION__DUCKLAKE__CREDENTIALS__AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
DESTINATION__DUCKLAKE__CREDENTIALS__AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
DESTINATION__DUCKLAKE__CREDENTIALS__REGION_NAME=${AWS_REGION}
DESTINATION__DUCKLAKE__CREDENTIALS__DUCKLAKE_NAME=${DUCKLAKE_NAME}

# football-data.org API
FOOTBALL_DATA_API_KEY=your_api_key
